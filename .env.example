# Server (Railway sets PORT automatically)
PORT=2567
NODE_ENV=production

# Persistent leaderboard (SQLite). Mount a Railway volume and set:
#   DATA_DIR=/data
# DB file: $DATA_DIR/gunmetal-barrage.db
# Falls back to ./data under the process cwd if unset.
# DATA_DIR=/data
# GMB_DATA_DIR=/data

# Client — only needed when client and server are on different origins.
# Leave unset on Railway so the production build uses same-origin wss://.
# Local Vite dev ignores this and uses ws://hostname:2567 unless set.
# VITE_SERVER_URL=wss://your-app.up.railway.app
